<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="536.0" prefWidth="648.0" spacing="0" style="-fx-background-color:#d4d0c8;-fx-font-family:Tahoma;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/23.0.1" fx:controller="com.lizardcontact.controller.StatistikController">

  <HBox alignment="CENTER_LEFT" style="-fx-padding:6 8;-fx-border-color:transparent transparent #808080 transparent;-fx-border-width:0 0 1 0;">
    <Label style="-fx-font-size:14;-fx-font-weight:bold;" text="Statistik Kontak" />
  </HBox>

  <!-- Summary cards -->
  <HBox spacing="6" style="-fx-padding:8 8 6 8;">
    <VBox alignment="CENTER" spacing="2" style="-fx-background-color:white;-fx-border-color:#808080 #ffffff #ffffff #808080;-fx-border-width:1;-fx-padding:5 8;" HBox.hgrow="ALWAYS">
      <Label style="-fx-font-size:10;" text="Total" />
      <Label fx:id="totalLabel" style="-fx-font-size:18;-fx-font-weight:bold;" text="0" />
    </VBox>
    <VBox alignment="CENTER" spacing="2" style="-fx-background-color:white;-fx-border-color:#808080 #ffffff #ffffff #808080;-fx-border-width:1;-fx-padding:5 8;" HBox.hgrow="ALWAYS">
      <Label style="-fx-font-size:10;" text="Terbanyak" />
      <Label fx:id="topLabel" style="-fx-font-size:14;-fx-font-weight:bold;" text="-" />
    </VBox>
    <VBox alignment="CENTER" spacing="2" style="-fx-background-color:white;-fx-border-color:#808080 #ffffff #ffffff #808080;-fx-border-width:1;-fx-padding:5 8;" HBox.hgrow="ALWAYS">
      <Label style="-fx-font-size:10;" text="Rata-rata" />
      <Label fx:id="avgLabel" style="-fx-font-size:18;-fx-font-weight:bold;" text="0" />
    </VBox>
    <VBox alignment="CENTER" spacing="2" style="-fx-background-color:white;-fx-border-color:#808080 #ffffff #ffffff #808080;-fx-border-width:1;-fx-padding:5 8;" HBox.hgrow="ALWAYS">
      <Label style="-fx-font-size:10;" text="Bulan Ini" />
      <Label fx:id="bulanLabel" style="-fx-font-size:18;-fx-font-weight:bold;" text="0" />
    </VBox>
    <VBox alignment="CENTER" spacing="2" style="-fx-background-color:white;-fx-border-color:#808080 #ffffff #ffffff #808080;-fx-border-width:1;-fx-padding:5 8;" HBox.hgrow="ALWAYS">
      <Label style="-fx-font-size:10;" text="P vs B" />
      <Label fx:id="pvbLabel" style="-fx-font-size:14;-fx-font-weight:bold;" text="0:0" />
    </VBox>
  </HBox>

  <!-- Tab chart -->
  <TabPane fx:id="chartTab" style="-fx-background-color:#d4d0c8;" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
    <VBox.margin><Insets left="8" right="8" /></VBox.margin>
    <Tab text="PieChart">
      <HBox spacing="8" style="-fx-padding:8;-fx-background-color:#d4d0c8;">
        <PieChart fx:id="pieChart" labelsVisible="true" legendVisible="true" prefHeight="220" prefWidth="241.0" HBox.hgrow="ALWAYS" />
      </HBox>
    </Tab>
    <Tab text="BarChart">
      <BarChart fx:id="barChart" prefHeight="220" style="-fx-background-color:#d4d0c8;">
        <xAxis><CategoryAxis label="Kategori" /></xAxis>
        <yAxis><NumberAxis label="Jumlah" /></yAxis>
      </BarChart>
    </Tab>
  </TabPane>

  <!-- Rincian table -->
  <VBox spacing="4" style="-fx-padding:0 8 8 8;">
    <Label style="-fx-font-size:11;-fx-font-weight:bold;" text="Rincian per Kategori:" />
    <TableView fx:id="rincianTable" prefHeight="150" style="-fx-font-size:11;-fx-background-color:white;-fx-border-color:#808080 #ffffff #ffffff #808080;-fx-border-width:1;">
      <columns>
        <TableColumn fx:id="colKat" prefWidth="101.33334350585938" text="Kategori" />
        <TableColumn fx:id="colJml" prefWidth="102.66665649414062" text="Jumlah" />
        <TableColumn fx:id="colPct" prefWidth="127.33331298828125" text="Persentase" />
        <TableColumn fx:id="colBar" prefWidth="300.66668701171875" text="Proporsi" />
      </columns>
      <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
    </TableView>
  </VBox>
</VBox>
