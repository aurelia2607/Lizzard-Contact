<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lizardcontact.controller.RegisterController"
      prefWidth="420" prefHeight="400"
      style="-fx-background-color: #d4d0c8; -fx-font-family: 'Tahoma';">

    <HBox style="-fx-background-color: #000080; -fx-padding: 3 6;">
        <Label text="Lizard Contact - Daftar Akun"
               style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11;"/>
    </HBox>

    <VBox alignment="CENTER" spacing="3" style="-fx-padding: 14 0 10 0;">
        <Label text="DAFTAR AKUN BARU"
               style="-fx-font-size: 14; -fx-font-weight: bold;"/>
        <Label text="Buat akun Lizard Contact baru"
               style="-fx-font-size: 11; -fx-text-fill: #444444;"/>
    </VBox>

    <Separator/>

    <VBox spacing="6" style="-fx-padding: 16 50 8 50;">
        <Label text="Username:" style="-fx-font-size: 12;"/>
        <TextField fx:id="usernameField" promptText="Buat username"
                   style="-fx-background-color: white; -fx-border-color: #808080 #ffffff #ffffff #808080; -fx-border-width: 1; -fx-padding: 3 5; -fx-font-size: 12;" prefHeight="24"/>

        <Label text="Email:" style="-fx-font-size: 12;"/>
        <TextField fx:id="emailField" promptText="Alamat email (opsional)"
                   style="-fx-background-color: white; -fx-border-color: #808080 #ffffff #ffffff #808080; -fx-border-width: 1; -fx-padding: 3 5; -fx-font-size: 12;" prefHeight="24"/>

        <Label text="Password:" style="-fx-font-size: 12;"/>
        <PasswordField fx:id="passwordField" promptText="Buat password"
                       style="-fx-background-color: white; -fx-border-color: #808080 #ffffff #ffffff #808080; -fx-border-width: 1; -fx-padding: 3 5; -fx-font-size: 12;" prefHeight="24"/>

        <Label text="Konfirmasi Password:" style="-fx-font-size: 12;"/>
        <PasswordField fx:id="confirmField" promptText="Ulangi password"
                       style="-fx-background-color: white; -fx-border-color: #808080 #ffffff #ffffff #808080; -fx-border-width: 1; -fx-padding: 3 5; -fx-font-size: 12;" prefHeight="24"/>

        <Label fx:id="errorLabel" text="" wrapText="true"
               style="-fx-text-fill: red; -fx-font-size: 11;" minHeight="16"/>
    </VBox>

    <Separator/>

    <HBox spacing="10" alignment="CENTER" style="-fx-padding: 14 0 14 0;">
        <Button text="Daftar" onAction="#register" prefWidth="90" prefHeight="26"
                style="-fx-background-color: #d4d0c8; -fx-border-color: #ffffff #808080 #808080 #ffffff; -fx-border-width: 2; -fx-font-size: 12; -fx-cursor: hand;"/>
        <Button text="Kembali" onAction="#backToLogin" prefWidth="90" prefHeight="26"
                style="-fx-background-color: #d4d0c8; -fx-border-color: #ffffff #808080 #808080 #ffffff; -fx-border-width: 2; -fx-font-size: 12; -fx-cursor: hand;"/>
    </HBox>
</VBox>
