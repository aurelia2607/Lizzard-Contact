<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lizardcontact.controller.FavoritController"
      style="-fx-background-color:#d4d0c8;-fx-font-family:Tahoma;" spacing="0">

  <HBox style="-fx-background-color:#d4d0c8;-fx-border-color:transparent transparent #808080 transparent;-fx-border-width:0 0 1 0;-fx-padding:6 8;" alignment="CENTER_LEFT">
    <Label text="★ Kontak Favorit" style="-fx-font-size:14;-fx-font-weight:bold;" HBox.hgrow="ALWAYS"/>
  </HBox>

  <HBox spacing="6" alignment="CENTER_LEFT" style="-fx-padding:6 8;-fx-border-color:transparent transparent #808080 transparent;-fx-border-width:0 0 1 0;">
    <Label text="Cari:" style="-fx-font-size:11;"/>
    <TextField fx:id="searchField" promptText="Cari di favorit..." prefWidth="180" prefHeight="22"
               style="-fx-background-color:white;-fx-border-color:#808080 #ffffff #ffffff #808080;-fx-border-width:1;-fx-padding:2 4;-fx-font-size:11;"/>
    <Button text="Cari" onAction="#doSearch" prefHeight="22" prefWidth="50"
            style="-fx-background-color:#d4d0c8;-fx-border-color:#ffffff #808080 #808080 #ffffff;-fx-border-width:2;-fx-font-size:11;-fx-cursor:hand;"/>
    <Button text="Reset" onAction="#resetSearch" prefHeight="22" prefWidth="55"
            style="-fx-background-color:#d4d0c8;-fx-border-color:#ffffff #808080 #808080 #ffffff;-fx-border-width:2;-fx-font-size:11;-fx-cursor:hand;"/>
    <HBox HBox.hgrow="ALWAYS"/>
    <Label text="Urut:" style="-fx-font-size:11;"/>
    <ComboBox fx:id="sortBox" prefWidth="110" prefHeight="22" style="-fx-font-size:11;"/>
  </HBox>

  <TableView fx:id="favTable" VBox.vgrow="ALWAYS"
             style="-fx-font-size:11;-fx-background-color:white;-fx-border-color:#808080 #ffffff #ffffff #808080;-fx-border-width:1;">
    <VBox.margin><Insets top="6" left="8" right="8" bottom="0"/></VBox.margin>
    <columns>
      <TableColumn fx:id="colNo"       text="No"       prefWidth="38"/>
      <TableColumn fx:id="colNama"     text="Nama"     prefWidth="170"/>
      <TableColumn fx:id="colTelepon"  text="Telepon"  prefWidth="120"/>
      <TableColumn fx:id="colKategori" text="Kategori" prefWidth="90"/>
      <TableColumn fx:id="colTipe"     text="Tipe"     prefWidth="75"/>
      <TableColumn fx:id="colAksi"     text="Aksi"     prefWidth="130"/>
    </columns>
    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
  </TableView>

  <HBox style="-fx-background-color:#d4d0c8;-fx-border-color:#808080 transparent transparent transparent;-fx-border-width:1 0 0 0;-fx-padding:4 8;" alignment="CENTER_LEFT" spacing="10">
    <Label fx:id="infoLabel" text="Menampilkan 0 favorit" style="-fx-font-size:11;" HBox.hgrow="ALWAYS"/>
    <Label fx:id="totalFavLabel" text="Total Favorit: 0 kontak" style="-fx-font-size:11;-fx-font-weight:bold;"/>
  </HBox>
</VBox>
