<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="526.0" prefWidth="657.0" spacing="0" style="-fx-background-color:#d4d0c8;-fx-font-family:Tahoma;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/23.0.1" fx:controller="com.lizardcontact.controller.RiwayatController">

  <!-- Header -->
  <VBox spacing="2" style="-fx-background-color:#d4d0c8;-fx-border-color:transparent transparent #808080 transparent;-fx-border-width:0 0 1 0;-fx-padding:6 8 4 8;">
    <Label style="-fx-font-size:13;-fx-font-weight:bold;" text="Riwayat Aktivitas" />
  </VBox>

  <!-- Filter row 1: Filter Aksi + date range + tombol -->
  <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding:6 8 2 8;-fx-background-color:#d4d0c8;">
    <Label style="-fx-font-size:11;" text="Filter Aksi:" />
    <ComboBox fx:id="filterAksi" prefHeight="22" prefWidth="110" style="-fx-font-size:11;" />
    <Label style="-fx-font-size:11;" text="Dari:" />
    <DatePicker fx:id="fromDate" prefHeight="22" prefWidth="135" promptText="DD/MM/YYYY" style="-fx-font-size:11;" />
    <Label style="-fx-font-size:11;" text="Sampai:" />
    <DatePicker fx:id="toDate" prefHeight="22" prefWidth="135" promptText="DD/MM/YYYY" style="-fx-font-size:11;" />
    <Button onAction="#doFilter" prefHeight="22" prefWidth="60" style="-fx-background-color:#d4d0c8;-fx-border-color:#ffffff #808080 #808080 #ffffff;-fx-border-width:2;-fx-font-size:11;-fx-cursor:hand;" text="Filter" />
    <Button onAction="#resetFilter" prefHeight="22" prefWidth="60" style="-fx-background-color:#d4d0c8;-fx-border-color:#ffffff #808080 #808080 #ffffff;-fx-border-width:2;-fx-font-size:11;-fx-cursor:hand;" text="Reset" />
  </HBox>

  <!-- Filter row 2: Hapus semua log -->
  <HBox style="-fx-padding:2 8 6 8;-fx-background-color:#d4d0c8;-fx-border-color:transparent transparent #808080 transparent;-fx-border-width:0 0 1 0;">
    <Button onAction="#hapusLog" prefHeight="22" style="-fx-background-color:#d4d0c8;-fx-border-color:#ffffff #808080 #808080 #ffffff;-fx-border-width:2;-fx-font-size:11;-fx-cursor:hand;" text="Hapus Semua Log" />
  </HBox>

  <!-- Table -->
  <TableView fx:id="logTable" editable="false" style="-fx-font-size:11;-fx-background-color:white;" VBox.vgrow="ALWAYS">
    <VBox.margin><Insets bottom="0" left="8" right="8" top="6" /></VBox.margin>
    <columns>
      <TableColumn fx:id="colNo" prefWidth="40" text="No" />
      <TableColumn fx:id="colWaktu" prefWidth="96.00000381469727" text="Waktu" />
      <TableColumn fx:id="colAksi" prefWidth="79.9999771118164" text="Aksi" />
      <TableColumn fx:id="colNama" prefWidth="189.33335876464844" text="Nama Kontak" />
      <TableColumn fx:id="colKet" prefWidth="257.3333435058594" text="Keterangan" />
    </columns>
    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
  </TableView>

  <!-- Footer -->
  <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color:#d4d0c8;-fx-border-color:#808080 transparent transparent transparent;-fx-border-width:1 0 0 0;-fx-padding:4 8;">
    <Label fx:id="totalLogLabel" style="-fx-font-size:11;" text="Total log: 0" HBox.hgrow="ALWAYS" />
    <Label fx:id="summaryLabel" style="-fx-font-size:11;-fx-font-weight:bold;" text="Tambah: 0 | Edit: 0 | Hapus: 0 | Favorit: 0" />
  </HBox>
</VBox>
