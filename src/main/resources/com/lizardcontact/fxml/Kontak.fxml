<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lizardcontact.controller.KontakController"
      style="-fx-background-color:#d4d0c8;-fx-font-family:Tahoma;" spacing="0">

  <!-- Header -->
  <HBox style="-fx-background-color:#d4d0c8;-fx-border-color:transparent transparent #808080 transparent;-fx-border-width:0 0 1 0;-fx-padding:6 8;" alignment="CENTER_LEFT">
    <Label text="Daftar Kontak" style="-fx-font-size:14;-fx-font-weight:bold;" HBox.hgrow="ALWAYS"/>
    <Button text="+ Tambah" onAction="#tambahKontak"
            style="-fx-background-color:#d4d0c8;-fx-border-color:#ffffff #808080 #808080 #ffffff;-fx-border-width:2;-fx-padding:3 10;-fx-font-size:11;-fx-cursor:hand;"/>
  </HBox>

  <!-- Filter bar -->
  <HBox spacing="6" alignment="CENTER_LEFT" style="-fx-padding:6 8;-fx-background-color:#d4d0c8;-fx-border-color:transparent transparent #808080 transparent;-fx-border-width:0 0 1 0;">
    <Label text="Cari:" style="-fx-font-size:11;"/>
    <TextField fx:id="searchField" promptText="Nama / Telepon / Email" prefWidth="180" prefHeight="22"
               style="-fx-background-color:white;-fx-border-color:#808080 #ffffff #ffffff #808080;-fx-border-width:1;-fx-padding:2 4;-fx-font-size:11;"/>
    <Label text="Kategori:" style="-fx-font-size:11;"/>
    <ComboBox fx:id="filterKategori" prefWidth="90" prefHeight="22" style="-fx-font-size:11;"/>
    <Label text="Tipe:" style="-fx-font-size:11;"/>
    <ComboBox fx:id="filterTipe" prefWidth="90" prefHeight="22" style="-fx-font-size:11;"/>
    <Button text="Cari" onAction="#doSearch" prefHeight="22" prefWidth="50"
            style="-fx-background-color:#d4d0c8;-fx-border-color:#ffffff #808080 #808080 #ffffff;-fx-border-width:2;-fx-font-size:11;-fx-cursor:hand;"/>
    <Button text="Reset" onAction="#resetSearch" prefHeight="22" prefWidth="55"
            style="-fx-background-color:#d4d0c8;-fx-border-color:#ffffff #808080 #808080 #ffffff;-fx-border-width:2;-fx-font-size:11;-fx-cursor:hand;"/>
  </HBox>

  <!-- Table -->
  <TableView fx:id="contactTable" VBox.vgrow="ALWAYS"
             style="-fx-font-size:11;-fx-background-color:white;-fx-border-color:#808080 #ffffff #ffffff #808080;-fx-border-width:1;"
             editable="false">
    <VBox.margin><Insets top="6" left="8" right="8" bottom="0"/></VBox.margin>
    <columns>
      <TableColumn fx:id="colNo"       text="No"       prefWidth="38"/>
      <TableColumn fx:id="colNama"     text="Nama"     prefWidth="150"/>
      <TableColumn fx:id="colTelepon"  text="Telepon"  prefWidth="115"/>
      <TableColumn fx:id="colEmail"    text="Email"    prefWidth="140"/>
      <TableColumn fx:id="colKategori" text="Kategori" prefWidth="80"/>
      <TableColumn fx:id="colTipe"     text="Tipe"     prefWidth="70"/>
      <TableColumn fx:id="colAksi"     text="Aksi"     prefWidth="150"/>
    </columns>
    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
  </TableView>

  <!-- Footer -->
  <HBox style="-fx-background-color:#d4d0c8;-fx-border-color:#808080 transparent transparent transparent;-fx-border-width:1 0 0 0;-fx-padding:4 8;" alignment="CENTER_LEFT" spacing="10">
    <Label fx:id="infoLabel" text="Menampilkan 0 kontak" style="-fx-font-size:11;" HBox.hgrow="ALWAYS"/>
    <Label fx:id="favInfo" text="Favorit: 0" style="-fx-font-size:11;-fx-font-weight:bold;"/>
  </HBox>
</VBox>
