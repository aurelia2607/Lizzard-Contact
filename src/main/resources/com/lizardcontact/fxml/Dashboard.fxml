<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lizardcontact.controller.DashboardController"
      style="-fx-background-color:#d4d0c8;-fx-font-family:Tahoma;" spacing="0">

  <!-- Header -->
  <VBox style="-fx-background-color:#d4d0c8;-fx-border-color:transparent transparent #808080 transparent;-fx-border-width:0 0 1 0;-fx-padding:6 8 4 8;" spacing="2">
    <Label text="Dashboard" style="-fx-font-size:13;-fx-font-weight:bold;"/>
    <Separator/>
    <Label fx:id="greetingLabel" text="Selamat datang!" style="-fx-font-size:11;"/>
  </VBox>

  <!-- Distribusi Kategori label -->
  <Label text="Distribusi Kategori:" style="-fx-font-size:11;-fx-font-weight:bold;-fx-padding:8 8 4 8;"/>

  <!-- Pie chart area -->
  <HBox VBox.vgrow="ALWAYS" style="-fx-padding:0 8 8 8;" spacing="0">
    <!-- Chart box with sunken border -->
    <VBox HBox.hgrow="ALWAYS"
          style="-fx-background-color:white;-fx-border-color:#808080 #ffffff #ffffff #808080;-fx-border-width:1;">
      <PieChart fx:id="pieChart" VBox.vgrow="ALWAYS"
                legendVisible="false" labelsVisible="false"
                prefHeight="320"/>
    </VBox>
    <!-- Legend panel kanan -->
    <VBox prefWidth="160" spacing="4"
          style="-fx-padding:8 8 0 12;-fx-alignment:TOP_LEFT;">
      <fx:define>
        <ToggleGroup fx:id="dummy"/>
      </fx:define>
      <ListView fx:id="legendList" prefWidth="150" VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent;-fx-border-color:transparent;-fx-font-size:11;"/>
    </VBox>
  </HBox>

  <!-- + Tambah Kontak button bottom right -->
  <HBox alignment="CENTER_RIGHT" style="-fx-padding:0 8 8 8;">
    <Button text="+ Tambah Kontak" onAction="#tambahKontak"
            style="-fx-background-color:#d4d0c8;-fx-border-color:#ffffff #808080 #808080 #ffffff;-fx-border-width:2;-fx-padding:4 12;-fx-font-size:11;-fx-cursor:hand;"/>
  </HBox>
</VBox>
