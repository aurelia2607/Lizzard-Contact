<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lizardcontact.controller.ContactFormController"
      style="-fx-background-color:#d4d0c8;-fx-font-family:Tahoma;" prefWidth="460" spacing="0">

  <!-- Header biru - X di ujung kanan pakai BorderPane -->
  <BorderPane style="-fx-background-color:#000080;-fx-padding:4 8;">
    <left>
      <Label fx:id="formTitle" text="Form Tambah Kontak"
             style="-fx-text-fill:white;-fx-font-weight:bold;-fx-font-size:12;"/>
    </left>
    <right>
      <Button text="X" onAction="#cancel"
              style="-fx-background-color:#d4d0c8;-fx-border-color:#ffffff #808080 #808080 #ffffff;-fx-border-width:2;-fx-padding:1 6;-fx-font-size:11;-fx-cursor:hand;-fx-font-weight:bold;"/>
    </right>
  </BorderPane>

  <!-- Tipe Kontak -->
  <HBox style="-fx-padding:8 12;-fx-border-color:transparent transparent #808080 transparent;-fx-border-width:0 0 1 0;" alignment="CENTER_LEFT" spacing="16">
    <Label text="Tipe Kontak:" style="-fx-font-size:12;-fx-font-weight:bold;"/>
    <RadioButton fx:id="rbPersonal" text="Personal" style="-fx-font-size:12;" selected="true">
      <toggleGroup><ToggleGroup fx:id="tipeGroup"/></toggleGroup>
    </RadioButton>
    <RadioButton fx:id="rbBisnis" text="Bisnis" style="-fx-font-size:12;" toggleGroup="$tipeGroup"/>
  </HBox>

  <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
              style="-fx-background-color:transparent;-fx-border-color:transparent;" prefHeight="400">
    <VBox spacing="0">

      <!-- Informasi Dasar -->
      <VBox spacing="4" style="-fx-padding:8 12 8 12;-fx-border-color:#808080;-fx-border-width:1;">
        <VBox.margin><Insets top="8" left="12" right="12"/></VBox.margin>
        <Label text="Informasi Dasar" style="-fx-font-size:11;-fx-font-weight:bold;"/>
        <Label text="Nama Lengkap *" style="-fx-font-size:11;"/>
        <TextField fx:id="nameField" promptText="cth: Budi Santoso"
                   style="-fx-background-color:white;-fx-border-color:#808080 #ffffff #ffffff #808080;-fx-border-width:1;-fx-padding:2 4;-fx-font-size:11;" prefHeight="22"/>
        <Label text="Nomor Telepon *" style="-fx-font-size:11;"/>
        <TextField fx:id="phoneField" promptText="081234567890"
                   style="-fx-background-color:white;-fx-border-color:#808080 #ffffff #ffffff #808080;-fx-border-width:1;-fx-padding:2 4;-fx-font-size:11;" prefHeight="22"/>
        <Label text="Email" style="-fx-font-size:11;"/>
        <TextField fx:id="emailField" promptText="budi@email.com"
                   style="-fx-background-color:white;-fx-border-color:#808080 #ffffff #ffffff #808080;-fx-border-width:1;-fx-padding:2 4;-fx-font-size:11;" prefHeight="22"/>
        <Label text="Alamat" style="-fx-font-size:11;"/>
        <TextField fx:id="addressField" promptText="Jl. ..."
                   style="-fx-background-color:white;-fx-border-color:#808080 #ffffff #ffffff #808080;-fx-border-width:1;-fx-padding:2 4;-fx-font-size:11;" prefHeight="22"/>
        <Label text="Kategori" style="-fx-font-size:11;"/>
        <ComboBox fx:id="kategoriBox" maxWidth="Infinity" prefHeight="22" style="-fx-font-size:11;"/>
        <CheckBox fx:id="favCheck" text="Tandai sebagai Favorit (★)" style="-fx-font-size:11;"/>
      </VBox>

      <!-- Data Personal -->
      <VBox fx:id="personalSection" spacing="4"
            style="-fx-padding:8 12 8 12;-fx-border-color:#808080;-fx-border-width:1;">
        <VBox.margin><Insets top="8" left="12" right="12"/></VBox.margin>
        <Label text="Data Personal" style="-fx-font-size:11;-fx-font-weight:bold;"/>
        <Label text="Nama Panggilan" style="-fx-font-size:11;"/>
        <TextField fx:id="nicknameField" promptText="cth: Budi"
                   style="-fx-background-color:white;-fx-border-color:#808080 #ffffff #ffffff #808080;-fx-border-width:1;-fx-padding:2 4;-fx-font-size:11;" prefHeight="22"/>
        <Label text="Tanggal Lahir (DD/MM/YYYY)" style="-fx-font-size:11;"/>
        <DatePicker fx:id="birthdatePicker" maxWidth="Infinity" prefHeight="22" style="-fx-font-size:11;"/>
        <Label text="Relasi" style="-fx-font-size:11;"/>
        <ComboBox fx:id="relasiBox" maxWidth="Infinity" prefHeight="22" style="-fx-font-size:11;"/>
      </VBox>

      <!-- Data Bisnis -->
      <VBox fx:id="bisnisSection" spacing="4"
            style="-fx-padding:8 12 8 12;-fx-border-color:#808080;-fx-border-width:1;"
            managed="false" visible="false">
        <VBox.margin><Insets top="8" left="12" right="12"/></VBox.margin>
        <Label text="Data Bisnis" style="-fx-font-size:11;-fx-font-weight:bold;"/>
        <Label text="Perusahaan" style="-fx-font-size:11;"/>
        <TextField fx:id="companyField" promptText="Nama perusahaan"
                   style="-fx-background-color:white;-fx-border-color:#808080 #ffffff #ffffff #808080;-fx-border-width:1;-fx-padding:2 4;-fx-font-size:11;" prefHeight="22"/>
        <Label text="Jabatan" style="-fx-font-size:11;"/>
        <TextField fx:id="jobTitleField" promptText="Jabatan / posisi"
                   style="-fx-background-color:white;-fx-border-color:#808080 #ffffff #ffffff #808080;-fx-border-width:1;-fx-padding:2 4;-fx-font-size:11;" prefHeight="22"/>
        <Label text="Website" style="-fx-font-size:11;"/>
        <TextField fx:id="websiteField" promptText="www.example.com"
                   style="-fx-background-color:white;-fx-border-color:#808080 #ffffff #ffffff #808080;-fx-border-width:1;-fx-padding:2 4;-fx-font-size:11;" prefHeight="22"/>
      </VBox>
      <VBox.margin><Insets bottom="8"/></VBox.margin>
    </VBox>
  </ScrollPane>

  <Label fx:id="errorLabel" text="" wrapText="true"
         style="-fx-text-fill:red;-fx-font-size:11;-fx-padding:2 12;"/>
  <Separator/>
  <HBox alignment="CENTER_RIGHT" spacing="8" style="-fx-padding:8 12;">
    <Button text="Batal" onAction="#cancel" prefWidth="80" prefHeight="26"
            style="-fx-background-color:#d4d0c8;-fx-border-color:#ffffff #808080 #808080 #ffffff;-fx-border-width:2;-fx-font-size:12;-fx-cursor:hand;"/>
    <Button text="Simpan" onAction="#save" prefWidth="80" prefHeight="26"
            style="-fx-background-color:#d4d0c8;-fx-border-color:#ffffff #808080 #808080 #ffffff;-fx-border-width:2;-fx-font-size:12;-fx-cursor:hand;-fx-font-weight:bold;"/>
  </HBox>
</VBox>
